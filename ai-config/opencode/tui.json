{
  "$schema": "https://opencode.ai/tui.json",
  "keymap": {
    "leader": "ctrl+x",
    "leader_timeout": 2000,
    "sections": {
      "global": {
        "model.list": "<leader>m,alt+p"
      },
      "session": {
        "session.line.up": "alt+u,ctrl+alt+y",
        "session.line.down": "alt+j,ctrl+alt+e"
      },
      "prompt": {
        "session.interrupt": "ctrl+c,escape",
        "prompt.editor": "<leader>e,ctrl+g"
      }
    }
  }
}
