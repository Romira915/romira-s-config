{
  "$schema": "https://opencode.ai/tui.json",
  "mouse": true,
  "keybinds": {
    "leader": "ctrl+x",
    "model_list": "<leader>m,alt+p",
    "messages_line_up": "alt+u,ctrl+alt+y",
    "messages_line_down": "alt+j,ctrl+alt+e",
    "session_interrupt": "ctrl+c,escape",
    "editor_open": "<leader>e,ctrl+g"
  }
}
