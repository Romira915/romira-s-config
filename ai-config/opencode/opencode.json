{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "prompt": "{file:./prompts/build.md}"
    },
    "title": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "newrelic": {
      "type": "remote",
      "url": "https://mcp.newrelic.com/mcp/",
      "enabled": true,
      "oauth": {
        "clientId": "pUWGgnjsQ0bydqCbavTPpw==",
        "authorizationUrl": "https://login.newrelic.com/login",
        "tokenUrl": "https://mcp.newrelic.com/oauth2/token",
        "scope": "openid"
      }
    },
    "workspace-mcp": {
      "type": "local",
      "command": ["uvx", "workspace-mcp", "--tool-tier", "core"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "GOOGLE_OAUTH_CLIENT_ID": "{file:~/.config/opencode/env/google-oauth-client-id}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "{file:~/.config/opencode/env/google-oauth-client-secret}",
        "OAUTHLIB_INSECURE_TRANSPORT": "1",
        "USER_GOOGLE_EMAIL": "{file:~/.config/opencode/env/user-google-email}"
      }
    }
  }
}
